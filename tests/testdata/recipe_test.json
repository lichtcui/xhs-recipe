  "steps": [
    {
      "title": "清洗排骨",
      "time": "约5分钟",
      "content": "排骨加入1勺面粉，倒入适量清水，用手抓洗清洗出血水，然后用清水冲洗干净，用厨房纸巾擦干水分"
    },
    {
      "title": "腌制",
      "time": "1小时",
      "content": "将擦干的排骨放入碗中，加入蒜、椒盐等调料，抓拌均匀，腌制1小时入味"
    },
    {
      "title": "烤制",
      "time": "25分钟",
      "content": "空气炸锅底部倒入少许清水，放入腌制好的排骨，表面喷一点油，设置180度烤25分钟，中途翻面一次"
    }
  ],
  "tips": [
    "空气炸锅底部加少许清水，是排骨烤出来鲜嫩多汁的关键",
    "大人吃可以按个人口味额外添加辣椒粉、孜然等调料",
    "腌制时间建议至少1小时，时间越久越入味"
  ],
